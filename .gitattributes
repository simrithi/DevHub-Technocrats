# Normalize all text files to LF on commit
* text=auto eol=lf

# Force LF for these file types
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.css text eol=lf
*.sql text eol=lf
*.sh text eol=lf
*.env text eol=lf
Dockerfile text eol=lf

# Binary files — no conversion
*.png binary
*.jpg binary
*.ico binary
*.pkl binary
*.joblib binary
